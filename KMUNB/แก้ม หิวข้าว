<script>
function goTo(){} // stub
// ── Apps Compare ────────────────────────────────────────
const ROOMS = {
  bedroom: {
    label: '🛏 ห้องนอน',
    devices: [
      { id:'ac',     emoji:'❄️', name:'แอร์',       cls:'ac',     watt:900,  fn:'เย็นมาก',   noise:'ปานกลาง', price:'฿12,000+' },
      { id:'fan',    emoji:'🌀', name:'พัดลม',      cls:'fan',    watt:50,   fn:'ปานกลาง',   noise:'น้อย',    price:'฿500–1,500' },
      { id:'light',  emoji:'💡', name:'ไฟห้องนอน',  cls:'light',  watt:15,   fn:'แสงสว่าง',  noise:'ไม่มี',   price:'฿80–300' },
      { id:'tv',     emoji:'📺', name:'ทีวีนอน',    cls:'tv',     watt:120,  fn:'บันเทิง',   noise:'น้อย',    price:'฿5,000+' },
    ]
  },
  living: {
    label: '🛋 ห้องนั่งเล่น',
    devices: [
      { id:'tv2',    emoji:'📺', name:'ทีวีใหญ่',   cls:'tv',     watt:200,  fn:'บันเทิง',   noise:'น้อย',    price:'฿15,000+' },
      { id:'ac2',    emoji:'❄️', name:'แอร์นั่งเล่น',cls:'ac',    watt:1200, fn:'เย็นมาก',   noise:'ปานกลาง', price:'฿18,000+' },
      { id:'fan2',   emoji:'🌀', name:'พัดลมตั้งพื้น',cls:'fan',  watt:60,   fn:'ปานกลาง',   noise:'น้อย',    price:'฿800–2,000' },
      { id:'router', emoji:'📡', name:'เราเตอร์',    cls:'router', watt:10,   fn:'อินเทอร์เน็ต',noise:'ไม่มี', price:'฿1,000–3,000' },
    ]
  },
  kitchen: {
    label: '🍳 ห้องครัว',
    devices: [
      { id:'fridge',  emoji:'🧊', name:'ตู้เย็น',     cls:'fridge', watt:150,  fn:'แช่เย็น',   noise:'น้อย',    price:'฿8,000+' },
      { id:'washer',  emoji:'🫧', name:'เครื่องซัก',  cls:'washer', watt:500,  fn:'ซักผ้า',    noise:'ปานกลาง', price:'฿7,000+' },
      { id:'heater',  emoji:'🌡', name:'เครื่องทำน้ำร้อน',cls:'heater',watt:3000,fn:'น้ำร้อน',noise:'น้อย',   price:'฿2,000+' },
      { id:'light2',  emoji:'💡', name:'ไฟครัว',      cls:'light',  watt:20,   fn:'แสงสว่าง',  noise:'ไม่มี',   price:'฿100–400' },
    ]
  }
};
 
let stateA = { room:'bedroom', device: ROOMS.bedroom.devices[0] };
let stateB = { room:'bedroom', device: ROOMS.bedroom.devices[1] };
 
function setRoom(slot, roomKey, tabEl) {
  const state = slot==='A' ? stateA : stateB;
  state.room = roomKey;
  // update tabs
  tabEl.closest('.room-tabs').querySelectorAll('.room-tab').forEach(t => t.classList.remove('active'));
  tabEl.classList.add('active');
  // auto-pick first device of new room
  state.device = ROOMS[roomKey].devices[0];
  renderGrid(slot);
  renderCompare();
}
 
function pickDevice(slot, devId) {
  const state = slot==='A' ? stateA : stateB;
  const room  = ROOMS[state.room];
  state.device = room.devices.find(d => d.id === devId) || room.devices[0];
  renderGrid(slot);
  renderCompare();
}
 
function renderGrid(slot) {
  const state = slot==='A' ? stateA : stateB;
  const grid  = document.getElementById('grid'+slot);
  const devs  = ROOMS[state.room].devices;
  grid.innerHTML = devs.map(d => `
    <div class="dg-item ${d.id===state.device.id?'selected':''}" onclick="pickDevice('${slot}','${d.id}')">
      <div class="dg-icon ${d.cls}"><span>${d.emoji}</span></div>
      <div class="dg-name">${d.name}</div>
      <div class="dg-watt">${d.watt}W</div>
    </div>`).join('');
}
 
function fmt(n)  { return '฿'+Math.round(n).toLocaleString('th-TH'); }
function fmtF(n) { return '฿'+n.toFixed(2); }
 
function renderCompare() {
  const a = stateA.device, b = stateB.device;
  const rate = 3.6;
  const cAh = a.watt/1000*rate, cBh = b.watt/1000*rate;
  const cAd = cAh*8,            cBd = cBh*8;
  const cAm = cAd*30,           cBm = cBd*30;
 
  // Big cards
  ['A','B'].forEach(s => {
    const d = s==='A'?a:b, st = s==='A'?stateA:stateB;
    document.getElementById('icon'+s).className = 'dev-big-icon '+d.cls;
    document.getElementById('icon'+s).querySelector('span').textContent = d.emoji;
    document.getElementById('name'+s).textContent  = d.name;
    document.getElementById('room'+s).textContent  = ROOMS[st.room].label;
    document.getElementById('watt'+s).textContent  = d.watt;
  });
 
  // Table headers
  document.getElementById('thA').textContent = a.name;
  document.getElementById('thB').textContent = b.name;
 
  // Watt
  const bW = a.watt <= b.watt;
  document.getElementById('rowWattA').innerHTML = a.watt+'<small>W</small>';
  document.getElementById('rowWattB').innerHTML = b.watt+'<small>W</small>';
  document.getElementById('rowWattA').className = 'ct-val'+(bW?' better':' worse');
  document.getElementById('rowWattB').className = 'ct-val'+(!bW?' better':' worse');
 
  // Cost/hr
  document.getElementById('rowCostA').textContent = fmtF(cAh);
  document.getElementById('rowCostB').textContent = fmtF(cBh);
  document.getElementById('rowCostA').className = 'ct-val'+(cAh<=cBh?' better':' worse');
  document.getElementById('rowCostB').className = 'ct-val'+(cBh<=cAh?' better':' worse');
 
  document.getElementById('rowDayA').textContent   = fmtF(cAd);
  document.getElementById('rowDayB').textContent   = fmtF(cBd);
  document.getElementById('rowMonthA').textContent = fmt(cAm);
  document.getElementById('rowMonthB').textContent = fmt(cBm);
  document.getElementById('rowCoolA').textContent  = a.fn;
  document.getElementById('rowCoolB').textContent  = b.fn;
  document.getElementById('rowNoiseA').textContent = a.noise;
  document.getElementById('rowNoiseB').textContent = b.noise;
  document.getElementById('rowPriceA').textContent = a.price;
  document.getElementById('rowPriceB').textContent = b.price;
 
  // Summary pills
  document.getElementById('sumDiff').textContent     = Math.abs(a.watt-b.watt)+' W';
  document.getElementById('sumCostDiff').textContent = fmtF(Math.abs(cAh-cBh));
  document.getElementById('sumMonthly').textContent  = fmt(Math.abs(cAm-cBm));
}
 
// init
renderGrid('A');
renderGrid('B');
renderCompare();
</script>
