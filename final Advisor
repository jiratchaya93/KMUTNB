function drawTempChart(progress, hoverIdx) {
  const canvas = getTempCanvas();
  if (!canvas) return;
  const wrap = document.getElementById('tempChartWrap');
  if (!wrap || wrap.clientWidth === 0) return;
 
  const W = wrap.clientWidth;
  const H = 128;
  const dpr = window.devicePixelRatio || 1;
  if (canvas.width !== W * dpr) {
    canvas.width  = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width  = W + 'px';
    canvas.style.height = H + 'px';
  }
  const ctx = canvas.getContext('2d');
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  ctx.clearRect(0, 0, W, H);
 
  const data   = [...TEMP_DATA.values];
  const n      = data.length;
  const pad    = { l:28, r:12, t:18, b:22 };
  const cw     = W - pad.l - pad.r;
  const ch     = H - pad.t - pad.b;
 
  // Dynamic scale — pad ±2° around actual min/max, rounded to nearest 5
  const dataMin = Math.min(...data);
  const dataMax = Math.max(...data);
  const minV = Math.floor((dataMin - 2) / 5) * 5;
  const maxV = Math.ceil((dataMax + 2) / 5) * 5;
  const range  = maxV - minV || 1;
 
  const px = i => pad.l + (i / (n-1)) * cw;
  const py = v => pad.t + ch - ((v - minV) / range) * ch;
 
  // Number of points to draw based on animation progress
  const drawN = Math.max(1, Math.round(progress * (n - 1) * 10) / 10);
 
  // Grid lines — 4 evenly spaced labels
  const step = Math.round((maxV - minV) / 4 / 5) * 5 || 5;
  for (let v = minV; v <= maxV; v += step) {
    const y = py(v);
    ctx.strokeStyle = 'rgba(180,100,80,0.07)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(W - pad.r, y); ctx.stroke();
    ctx.fillStyle = 'rgba(156,123,116,0.65)';
    ctx.font = '8px DM Sans, sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText(v + '°', pad.l - 3, y + 3);
  }
 
  // Bars (animated height)
  const barW = Math.min(28, cw / n * 0.55);
  data.forEach((v, i) => {
    if (i > drawN) return;
    const barProgress = Math.min(1, drawN - i + 1);
    const barH = ((v - minV) / range) * ch * Math.max(0, barProgress);
    const x = px(i) - barW / 2;
    const y = py(v);
    const isHov = i === hoverIdx;
    const isLive = i === n - 1;
 
    // Bar gradient
    const bg = ctx.createLinearGradient(0, y, 0, py(minV));
    bg.addColorStop(0, isHov ? 'rgba(251,146,60,1)' : isLive ? 'rgba(224,112,96,0.95)' : 'rgba(251,146,60,0.82)');
    bg.addColorStop(1, 'rgba(253,186,116,0.3)');
    ctx.fillStyle = bg;
 
    // Rounded rect
    const actualY = py(minV) - barH;
    const r = 5;
    ctx.beginPath();
    ctx.moveTo(x + r, actualY);
    ctx.lineTo(x + barW - r, actualY);
    ctx.quadraticCurveTo(x + barW, actualY, x + barW, actualY + r);
    ctx.lineTo(x + barW, py(minV));
    ctx.lineTo(x, py(minV));
    ctx.lineTo(x, actualY + r);
    ctx.quadraticCurveTo(x, actualY, x + r, actualY);
    ctx.closePath();
    ctx.fill();
 
    // Hover glow
    if (isHov) {
      ctx.shadowColor = 'rgba(251,146,60,0.4)';
      ctx.shadowBlur  = 10;
      ctx.fill();
      ctx.shadowBlur = 0;
    }
  });
 
  // Line + area (animated draw)
  const linePoints = data.map((v,i) => ({ x: px(i), y: py(v) }));
  const partialN = Math.min(n, Math.floor(drawN) + 1);
  const frac     = drawN % 1;
 
  // Area fill
  if (partialN >= 2) {
    const areaGrad = ctx.createLinearGradient(0, pad.t, 0, pad.t + ch);
    areaGrad.addColorStop(0, 'rgba(251,191,36,0.22)');
    areaGrad.addColorStop(1, 'rgba(251,191,36,0)');
    ctx.beginPath();
    ctx.moveTo(linePoints[0].x, linePoints[0].y);
    for (let i = 1; i < partialN; i++) {
      const p = i < partialN - 1 ? linePoints[i] : {
        x: linePoints[i-1].x + (linePoints[Math.min(i, n-1)].x - linePoints[i-1].x) * (i === partialN-1 ? frac || 1 : 1),
        y: linePoints[i-1].y + (linePoints[Math.min(i, n-1)].y - linePoints[i-1].y) * (i === partialN-1 ? frac || 1 : 1)
      };
      ctx.lineTo(p.x, p.y);
    }
    ctx.lineTo(linePoints[Math.min(partialN-1, n-1)].x, py(minV));
    ctx.lineTo(linePoints[0].x, py(minV));
    ctx.closePath();
    ctx.fillStyle = areaGrad;
    ctx.fill();
  }
 
  // Line stroke
  if (partialN >= 2) {
    const lineGrad = ctx.createLinearGradient(pad.l, 0, W - pad.r, 0);
    lineGrad.addColorStop(0, '#fbbf24');
    lineGrad.addColorStop(1, '#f59e0b');
    ctx.beginPath();
    ctx.moveTo(linePoints[0].x, linePoints[0].y);
    for (let i = 1; i < partialN; i++) {
      const endX = i < partialN - 1 ? linePoints[i].x : linePoints[i-1].x + (linePoints[Math.min(i,n-1)].x - linePoints[i-1].x) * (frac || 1);
      const endY = i < partialN - 1 ? linePoints[i].y : linePoints[i-1].y + (linePoints[Math.min(i,n-1)].y - linePoints[i-1].y) * (frac || 1);
      ctx.lineTo(endX, endY);
    }
    ctx.strokeStyle = lineGrad;
    ctx.lineWidth   = 2.2;
    ctx.lineJoin    = 'round';
    ctx.lineCap     = 'round';
    ctx.stroke();
  }
 
  // Dots + labels
  data.forEach((v, i) => {
    if (i > drawN) return;
    const x = px(i), y = py(v);
    const isHov  = i === hoverIdx;
    const isPeak = v === Math.max(...data);
    const isLive = i === n - 1;
 
    // Glow ring on hover
    if (isHov) {
      ctx.beginPath(); ctx.arc(x, y, 9, 0, Math.PI*2);
      ctx.fillStyle = isPeak ? 'rgba(224,112,96,0.2)' : 'rgba(251,146,60,0.2)';
      ctx.fill();
    }
    // Dot
    ctx.beginPath(); ctx.arc(x, y, isHov ? 5.5 : isPeak ? 5 : 3.8, 0, Math.PI*2);
    ctx.fillStyle = isPeak ? '#e07060' : isLive ? '#fb923c' : '#f59e0b';
    ctx.fill();
    ctx.strokeStyle = 'white'; ctx.lineWidth = 1.8;
    ctx.stroke();
 
    // Temp label above
    if (!isHov) {
      ctx.font = `${isPeak ? 'bold ' : ''}8.5px DM Sans, sans-serif`;
      ctx.fillStyle = isPeak ? '#e07060' : '#c2700a';
      ctx.textAlign = 'center';
      ctx.fillText(v + '°' + (isPeak ? '🔥' : ''), x, y - 7);
    }
  });
 
  // X-axis labels
  ctx.font = '8px DM Sans, sans-serif';
  ctx.fillStyle = 'rgba(156,123,116,0.7)';
  ctx.textAlign = 'center';
  TEMP_DATA.times.forEach((t, i) => {
    ctx.fillText(t, px(i), H - 4);
  });
}
 
function tempIntroAnimate() {
  tempAnimProgress += 0.04;
  if (tempAnimProgress >= 1) {
    tempAnimProgress = 1;
    drawTempChart(1, tempHoverIdx);
    startTempLive();
    return;
  }
  const eased = 1 - Math.pow(1 - tempAnimProgress, 3);
  drawTempChart(eased, tempHoverIdx);
  tempAnimRAF = requestAnimationFrame(tempIntroAnimate);
}
 
// ── Real-time smooth fluctuation ────────────────────────
// Each tick: ALL points drift ±0.02°C max toward a slow-moving target
// Gives gentle wave motion — no random spike
let tempRealTimeRAF  = null;
let tempTargets      = [];   // target value per point (drifts slowly)
let tempTargetTimer  = 0;    // countdown to next target shift
const TICK_MS        = 1000 / 30; // ~30fps smooth
const DRIFT_PER_TICK = 0.02;      // max °C change per tick toward target
const TARGET_RANGE   = 0.4;       // targets drift ±0.4°C from base values
let tempBaseValues   = [];        // snapshot of API values as baseline
let tempLastTick     = 0;
 
function startTempLive() {
  if (tempRealTimeRAF) cancelAnimationFrame(tempRealTimeRAF);
 
  // Freeze all points except the last one
  tempBaseValues = [...TEMP_DATA.values];
  let liveTarget = tempBaseValues[tempBaseValues.length - 1];
  let liveVal    = liveTarget;
  let targetTimer = 0;
  tempLastTick = 0;
 
  function tick(ts) {
    if (!tempLastTick) tempLastTick = ts;
    const dt = ts - tempLastTick;
    tempLastTick = ts;
 
    targetTimer -= dt;
    if (targetTimer <= 0) {
      // Drift target ±0.4°C from base — gentle realistic fluctuation
      const base  = tempBaseValues[tempBaseValues.length - 1];
      liveTarget  = Math.round((base + (Math.random() * 0.8 - 0.4)) * 100) / 100;
      targetTimer = 3000 + Math.random() * 4000; // every 3–7s pick new target
    }
 
    // Move liveVal toward target by max ±0.02°C per tick
    const diff = liveTarget - liveVal;
    if (Math.abs(diff) > 0.001) {
      liveVal = Math.round((liveVal + Math.sign(diff) * Math.min(DRIFT_PER_TICK, Math.abs(diff))) * 100) / 100;
 
      // Update ONLY last data point
      TEMP_DATA.values[TEMP_DATA.values.length - 1] = liveVal;
 
      drawTempChart(1, tempHoverIdx);
 
      // Update header display
      const peakEl = document.getElementById('tempPeakVal');
      if (peakEl) peakEl.textContent = liveVal.toFixed(2) + '°C';
    }
 
    tempRealTimeRAF = requestAnimationFrame(tick);
  }
 
  tempRealTimeRAF = requestAnimationFrame(tick);
 
  // Re-fetch from API every 5 min to update baseline
  if (owmLiveInt) clearInterval(owmLiveInt);
  owmLiveInt = setInterval(refreshTempData, 5 * 60 * 1000);
}
 
function initTempChart() {
  const canvas = getTempCanvas();
  if (!canvas) return;
 
  // Hover / touch events
  const showTooltip = (clientX, clientY) => {
    const rect  = canvas.getBoundingClientRect();
    const x     = clientX - rect.left;
    const n     = TEMP_DATA.values.length;
    const W     = rect.width;
    const padL  = 28, padR = 12;
    const cw    = W - padL - padR;
    // Find nearest point
    let closest = 0, minD = Infinity;
    for (let i = 0; i < n; i++) {
      const px = padL + (i / (n-1)) * cw;
      const d  = Math.abs(x - px);
      if (d < minD) { minD = d; closest = i; }
    }
    if (minD > cw / n) { hideTooltip(); return; }
    tempHoverIdx = closest;
    drawTempChart(1, tempHoverIdx);
 
    const tip = document.getElementById('tempTooltip');
    const vals = TEMP_DATA.values;
    const dMin = Math.min(...vals), dMax = Math.max(...vals);
    const mV = Math.floor((dMin-3)/5)*5, xV = Math.ceil((dMax+3)/5)*5;
    const v    = vals[closest];
    const t    = TEMP_DATA.times[closest];
    tip.textContent = `🌡 ${v}°C · ${t}`;
    const px2  = padL + (closest / (n-1)) * cw;
    const py2  = 18 + (128-40) - ((v - mV) / (xV - mV)) * (128-40);
    tip.style.left    = (px2 / W * 100) + '%';
    tip.style.top     = Math.max(10, py2 - 14) + 'px';
    tip.style.display = 'block';
  };
  const hideTooltip = () => {
    tempHoverIdx = -1;
    drawTempChart(1, -1);
    const tip = document.getElementById('tempTooltip');
    if (tip) tip.style.display = 'none';
  };
 
  canvas.addEventListener('mousemove',  e => showTooltip(e.clientX, e.clientY));
  canvas.addEventListener('mouseleave', () => hideTooltip());
  canvas.addEventListener('touchstart', e => { e.preventDefault(); showTooltip(e.touches[0].clientX, e.touches[0].clientY); }, {passive:false});
  canvas.addEventListener('touchmove',  e => { e.preventDefault(); showTooltip(e.touches[0].clientX, e.touches[0].clientY); }, {passive:false});
  canvas.addEventListener('touchend',   () => setTimeout(hideTooltip, 1200));
 
  // Start intro animation
  if (tempAnimRAF) cancelAnimationFrame(tempAnimRAF);
  tempAnimProgress = 0;
  tempIntroAnimate();
}
 
