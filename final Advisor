            <svg viewBox="0 0 48 48" fill="none"><defs><linearGradient id="an4" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#f5c0b0"/><stop offset="100%" stop-color="#d4685a"/></linearGradient></defs>
