<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title>Energy Advisor</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --rose: #e8a598; --rose-dk: #c97b6e; --rose-lt: #f5d5cc;
      --cream: #fdf6f2; --text: #3a2a25; --muted: #9c7b74;
      --glass: rgba(255,255,255,0.72);
      --shadow: 0 8px 28px rgba(180,100,80,0.13);
      --shadow-sm: 0 4px 14px rgba(180,100,80,0.09);
    }
    html, body {
      height: 100%; font-family: "DM Sans", sans-serif;
      background: var(--cream);
      display: flex; justify-content: center; align-items: center;
      overflow: hidden;
    }
    body::before, body::after {
      content: ""; position: fixed; border-radius: 50%;
      filter: blur(80px); opacity: 0.48; pointer-events: none; z-index: 0;
    }
    body::before {
      width: 520px; height: 520px;
      background: radial-gradient(circle, #f0b8a8, #f5d5cc);
      top: -120px; right: -80px;
      animation: drift1 12s ease-in-out infinite alternate;
    }
    body::after {
      width: 400px; height: 400px;
      background: radial-gradient(circle, #e8cfc8, #f8ebe6);
      bottom: -100px; left: -60px;
      animation: drift2 14s ease-in-out infinite alternate;
    }
    @keyframes drift1 { to { transform: translate(-30px,40px) scale(1.05); } }
    @keyframes drift2 { to { transform: translate(30px,-30px) scale(1.08); } }
    .petal {
      position: fixed; border-radius: 0 60% 0 60%;
      background: rgba(232,165,152,0.32); pointer-events: none;
      animation: fall linear infinite; z-index: 0;
    }
    @keyframes fall {
      0% { transform: translateY(-20px) rotate(0deg); opacity: 0; }
      10% { opacity: 1; } 90% { opacity: 0.45; }
      100% { transform: translateY(110vh) rotate(720deg) scale(0.4); opacity: 0; }
    }
    .phone {
      position: relative; z-index: 10;
      width: 375px; height: 780px; display: flex; flex-direction: column;
      background: rgba(255,255,255,0.72);
      backdrop-filter: blur(22px); -webkit-backdrop-filter: blur(22px);
      border: 1px solid rgba(255,255,255,0.82); border-radius: 40px;
      box-shadow: 0 20px 60px rgba(180,100,80,0.15), inset 0 1px 0 rgba(255,255,255,0.9);
      overflow: hidden;
      animation: rise 0.8s cubic-bezier(0.16,1,0.3,1) both;
    }
    @keyframes rise {
      from { opacity: 0; transform: translateY(36px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .phone::before {
      content: ""; position: absolute; top: 0; left: 40px; right: 40px; height: 3px;
      background: linear-gradient(90deg, transparent, var(--rose), transparent);
      border-radius: 0 0 4px 4px; z-index: 20; pointer-events: none;
    }
    @keyframes fadein { from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);} }
    .fi { animation: fadein 0.5s cubic-bezier(0.16,1,0.3,1) both; }
    .avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, #f2b8a8, #e88070);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 12px rgba(232,128,112,0.3); font-size: 15px;
    }
    .bottom-nav {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 10px 20px 18px;
      background: rgba(253,246,242,0.9); backdrop-filter: blur(16px);
      border-top: 1px solid rgba(232,165,152,0.14); z-index: 100; border-radius: 0 0 40px 40px;
    }
    .nav-row { display: flex; justify-content: space-around; align-items: center; }
    .nav-item { display: flex; flex-direction: column; align-items: center; gap: 5px; cursor: pointer; }
    .nav-icon {
      width: 58px; height: 58px; border-radius: 16px;
      background: rgba(255,255,255,0.62); border: 1px solid rgba(255,255,255,0.88);
      box-shadow: 0 4px 16px rgba(180,90,70,0.10), inset 0 1px 0 rgba(255,255,255,0.95);
      display: flex; align-items: center; justify-content: center;
      position: relative; overflow: hidden; transition: transform 0.18s;
    }
    .nav-icon::before {
      content: ""; position: absolute; top: 0; left: 0; right: 0; height: 52%;
      background: linear-gradient(to bottom, rgba(255,255,255,0.55), rgba(255,255,255,0.08));
      border-radius: 16px 16px 60% 60% / 16px 16px 40% 40%;
      pointer-events: none; z-index: 2;
    }
    .nav-icon.active-icon {
      background: linear-gradient(135deg, #efaa9a, #e07060);
      box-shadow: 0 6px 20px rgba(224,112,96,0.38), inset 0 1px 0 rgba(255,255,255,0.35);
    }
    .nav-icon svg { width: 32px; height: 32px; position: relative; z-index: 1; }
    .nav-label { font-size: 10.5px; color: var(--muted); font-weight: 400; }
    .nav-label.active-label { color: var(--rose-dk); font-weight: 500; }
    .sec-label { display:flex;justify-content:space-between;align-items:baseline;margin:6px 4px 8px; }
    .sec-label h2 { font-size:15px;font-weight:500;color:var(--text); }
    .sec-label>span { font-size:11px;color:var(--rose-dk); }
    .sec-sub { font-size:11px;color:var(--muted);font-weight:300;margin-left:4px; }
    #v-advisor { background: transparent; }
    .adv-header {
      padding: 18px 22px 10px;
      display: flex; justify-content: space-between; align-items: center; flex-shrink: 0;
    }
    .adv-header h1 {
      font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 400;
      color: var(--text); letter-spacing: 0.01em;
    }
    .adv-header p { font-size: 11.5px; color: var(--muted); font-weight: 300; margin-top: 1px; }
    .adv-content {
      flex: 1; overflow-y: auto; padding: 0 16px 108px;
      -webkit-overflow-scrolling: touch; scrollbar-width: none;
    }
    .adv-content::-webkit-scrollbar { display: none; }
    .temp-card {
      background: var(--glass); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.82); border-radius: 24px;
      padding: 16px 16px 14px; box-shadow: var(--shadow); position: relative; overflow: hidden;
    }
    .temp-card::before {
      content: ''; position: absolute; top: 0; left: 30px; right: 30px; height: 2.5px;
      background: linear-gradient(90deg, transparent, var(--rose), transparent); border-radius: 0 0 3px 3px;
    }
    .temp-hdr { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
    .temp-icon-grp { display: flex; align-items: center; gap: 8px; }
    .temp-icon-bg {
      width: 34px; height: 34px; border-radius: 10px;
      background: linear-gradient(135deg, #ffca7a, #ff8c42);
      display: flex; align-items: center; justify-content: center; font-size: 16px;
      box-shadow: 0 4px 12px rgba(255,140,66,0.3);
    }
    .temp-ttl { font-size: 13px; font-weight: 500; color: var(--text); }
    .temp-sbt { font-size: 11px; color: var(--muted); font-weight: 300; }
    .temp-peak-val {
      font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 400;
      color: #e07060; line-height: 1; text-align: right;
    }
    .temp-peak-lbl { font-size: 10px; color: var(--muted); font-weight: 300; margin-top: 2px; text-align: right; }
    .rec-hdr-row { display: flex; align-items: center; gap: 10px; margin: 16px 4px 12px; }
    .bulb-icon {
      width: 34px; height: 34px; border-radius: 10px;
      background: linear-gradient(135deg, #fde68a, #f59e0b);
      display: flex; align-items: center; justify-content: center; font-size: 17px;
      box-shadow: 0 4px 14px rgba(245,158,11,0.35); flex-shrink: 0;
      animation: glow 2.5s ease-in-out infinite;
    }
    @keyframes glow {
      0%,100% { box-shadow: 0 4px 14px rgba(245,158,11,0.35); }
      50%      { box-shadow: 0 4px 22px rgba(245,158,11,0.6); }
    }
    @keyframes tempPulse {
      0%   { transform: scale(1); opacity: 0.7; }
      100% { transform: scale(3); opacity: 0; }
    }
    @keyframes tempBlink {
      0%,100% { opacity: 1; } 50% { opacity: 0.3; }
    }
    .rec-hdr-text h3 { font-size: 14px; font-weight: 500; color: var(--text); }
    .rec-hdr-text p  { font-size: 11px; color: var(--muted); font-weight: 300; }
    .sug-card {
      background: rgba(255,255,255,0.78); border: 1px solid rgba(232,165,152,0.18);
      border-radius: 20px; padding: 13px 15px;
      display: flex; align-items: center; gap: 12px;
      box-shadow: var(--shadow-sm); margin-bottom: 10px;
      transition: transform 0.18s, box-shadow 0.18s; cursor: pointer;
    }
    .sug-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(180,90,70,0.14); }
    .sug-ico {
      width: 46px; height: 46px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; font-size: 22px; position: relative; overflow: hidden;
    }
    .sug-ico::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 50%;
      background: linear-gradient(to bottom, rgba(255,255,255,0.45), rgba(255,255,255,0.05));
      border-radius: 14px 14px 60% 60% / 14px 14px 30% 30%; z-index: 1; pointer-events: none;
    }
    .sug-ico span { position: relative; z-index: 2; }
    .sug-ico.ac { background: linear-gradient(135deg,#dbeafe,#93c5fd); box-shadow: 0 4px 12px rgba(147,197,253,0.4); }
    .sug-ico.tv { background: linear-gradient(135deg,#fce7f3,#f9a8d4); box-shadow: 0 4px 12px rgba(249,168,212,0.4); }
    .sug-bdy { flex: 1; min-width: 0; }
    .sug-ttl { font-size: 13px; font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sug-tme { font-size: 11px; color: var(--muted); font-weight: 300; margin-top: 2px; }
    .sug-bdg { flex-shrink: 0; font-size: 13px; font-weight: 500; padding: 5px 11px; border-radius: 12px; white-space: nowrap; }
    .sug-bdg.save { background: rgba(125,206,130,0.14); color: #3a8a40; }
    .sug-bdg.cost { background: rgba(232,165,152,0.18); color: var(--rose-dk); }
 
    /* ── Swipeable Rec Card ── */
    .rec-swipe-wrap {
      position: relative; overflow: hidden;
      border-radius: 20px; margin-bottom: 0;
      /* Stagger slide-in */
      opacity: 0; transform: translateX(-28px);
      transition: opacity 0.45s cubic-bezier(0.16,1,0.3,1),
                  transform 0.45s cubic-bezier(0.16,1,0.3,1);
    }
    .rec-swipe-wrap.visible { opacity: 1; transform: translateX(0); }
 
    /* Action background (revealed on swipe) */
    .rec-action-bg {
      position: absolute; inset: 0; border-radius: 20px;
      display: flex; align-items: center;
      justify-content: flex-end; padding-right: 20px;
      font-size: 13px; font-weight: 600;
    }
    .rec-action-bg.done {
      background: linear-gradient(135deg, #6ee7b7, #34d399);
      color: white; justify-content: flex-end;
    }
    .rec-action-bg.dismiss {
      background: linear-gradient(135deg, #fca5a5, #f87171);
      color: white; justify-content: flex-start;
      padding-left: 20px; padding-right: 0;
    }
 
    /* Card front */
    .rec-card-front {
      position: relative; z-index: 2;
      background: rgba(255,255,255,0.82);
      border: 1px solid rgba(232,165,152,0.18);
      border-radius: 20px; padding: 13px 15px;
      display: flex; align-items: center; gap: 12px;
      box-shadow: 0 4px 14px rgba(180,90,70,0.09);
      transition: transform 0.08s linear, box-shadow 0.2s;
      cursor: grab; user-select: none;
      will-change: transform;
    }
    .rec-card-front.swiping { transition: none; }
    .rec-card-front.snap-back {
      transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
    }
    .rec-card-front.snap-out {
      transition: transform 0.3s ease-in, opacity 0.3s ease-in;
      opacity: 0;
    }
 
    /* Hint pulse on first load */
    @keyframes swipeHint {
      0%   { transform: translateX(0); }
      20%  { transform: translateX(-18px); }
      50%  { transform: translateX(10px); }
      75%  { transform: translateX(-6px); }
      100% { transform: translateX(0); }
    }
    .rec-card-front.hint { animation: swipeHint 0.8s cubic-bezier(0.36,0.07,0.19,0.97) both; }
 
    /* Completed state */
    .rec-swipe-wrap.completed .rec-card-front {
      opacity: 0.45; filter: grayscale(0.4);
    }
    .rec-done-badge {
      position: absolute; top: 8px; right: 10px; z-index: 3;
      background: #34d399; color: white; font-size: 10px; font-weight: 600;
  </style>
</head>
