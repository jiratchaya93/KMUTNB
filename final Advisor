// ── Fetch current weather (real-time anchor point) ──────
async function fetchOWMCurrent(cityKey) {
  if (!OWM_KEY) return null;
  const city = OWM_CITIES[cityKey];
  try {
    const res = await fetch(
      `https://api.openweathermap.org/data/2.5/weather?lat=${city.lat}&lon=${city.lon}&appid=${OWM_KEY}&units=metric`
    );
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const j = await res.json();
    const now = new Date();
    return {
      time:     now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0'),
      temp:     Math.round(j.main.temp * 10) / 10,
      feels:    Math.round(j.main.feels_like * 10) / 10,
      humidity: j.main.humidity,
      desc:     j.weather[0].description,
    };
  } catch(e) {
    console.warn('OWM current failed:', e.message);
    return null;
  }
}
 
// ── Fetch hourly forecast (3h intervals × 5 slots) ───────
async function fetchOWMHourly(cityKey) {
  if (!OWM_KEY) return null;
  const city = OWM_CITIES[cityKey];
  try {
    const res = await fetch(
      `https://api.openweathermap.org/data/2.5/forecast?lat=${city.lat}&lon=${city.lon}&appid=${OWM_KEY}&units=metric&cnt=5`
    );
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const j = await res.json();
    if (!j.list || j.list.length === 0) throw new Error('No data');
    return j.list.map(s => {
      const d = new Date(s.dt * 1000);
      return {
        time: d.getHours().toString().padStart(2,'0') + ':00',
        temp: Math.round(s.main.temp * 10) / 10,
      };
    });
  } catch(e) {
    console.warn('OWM forecast failed:', e.message);
    return null;
  }
}
 
