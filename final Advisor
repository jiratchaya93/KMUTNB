            <div style="width:10px;height:8px;border-radius:2px;background:linear-gradient(to top,#fb923c,#fdba74);opacity:.85;"></div>
            <span style="font-size:8px;color:rgba(156,123,116,0.85);">อุณหภูมิ (bar)</span>
          </div>
          <div style="display:flex;align-items:center;gap:5px;">
            <div style="width:16px;height:2px;background:#f59e0b;border-radius:2px;position:relative;">
              <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:5px;height:5px;border-radius:50%;background:#f59e0b;"></div>
            </div>
            <span style="font-size:8px;color:rgba(156,123,116,0.85);">แนวโน้ม (line)</span>
          </div>
          <div id="tempLiveLabel" style="display:flex;align-items:center;gap:4px;margin-left:auto;">
            <div style="width:6px;height:6px;border-radius:50%;background:#7dce82;animation:tempBlink 1.2s ease-in-out infinite;"></div>
            <span style="font-size:8px;color:#5aaa60;font-weight:500;">LIVE</span>
          </div>
        </div>
      </div>
 
      <!-- Recommendations header -->
      <div class="rec-hdr-row fi" style="animation-delay:.25s">
        <div class="bulb-icon">💡</div>
        <div class="rec-hdr-text">
          <h3>คำแนะนำ เพื่อลดค่าไฟ</h3>
          <p>Energy Saving Recommendations</p>
        </div>
      </div>
 
      <!-- Swipeable Recommendation Cards -->
      <div id="recCardsWrap" style="display:flex;flex-direction:column;gap:10px;"></div>
 
    </div><!-- end adv-content -->
 
