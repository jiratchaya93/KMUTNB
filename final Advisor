  REC_CARDS.forEach((card, idx) => {
    if (recState[card.id] === 'dismissed') return;
 
    const isDone = recState[card.id] === 'done';
 
    const outer = document.createElement('div');
    outer.className = 'rec-swipe-wrap' + (isDone ? ' completed' : '');
    outer.id = 'rw-' + card.id;
    outer.style.transitionDelay = (idx * 0.08) + 's';
 
    outer.innerHTML = `
      <div class="rec-action-bg done">✓ ทำแล้ว!</div>
      <div class="rec-action-bg dismiss">✕ ข้าม</div>
      <div class="rec-card-front" id="rf-${card.id}">
        ${isDone ? `<div class="rec-done-badge">✓ ทำแล้ว</div>` : ''}
        <div class="sug-ico ${card.ico}"><span>${card.emoji}</span></div>
        <div class="sug-bdy">
          <div class="sug-ttl">${card.title}</div>
          <div class="sug-tme">${card.sub}</div>
        </div>
        <div class="sug-bdg ${card.type}">${card.badge}</div>
      </div>`;
 
    wrap.appendChild(outer);
 
    // Stagger entrance
    requestAnimationFrame(() => {
      setTimeout(() => outer.classList.add('visible'), idx * 90 + 30);
    });
 
    // Swipe hint on first card only
    if (idx === 0 && !isDone) {
      setTimeout(() => {
        const front = document.getElementById('rf-' + card.id);
        if (front) front.classList.add('hint');
      }, 800 + idx * 90);
    }
 
    initSwipe(card.id);
  });
}
 
function initSwipe(cardId) {
  const front = document.getElementById('rf-' + cardId);
  const outer = document.getElementById('rw-' + cardId);
  if (!front || !outer) return;
 
  let startX = 0, currentX = 0, dragging = false;
  const THRESHOLD = 80; // px to trigger action
 
  function onStart(x) {
    startX   = x;
    currentX = 0;
    dragging = true;
    front.classList.add('swiping');
    front.classList.remove('snap-back', 'hint');
  }
 
  function onMove(x) {
    if (!dragging) return;
    currentX = x - startX;
 
    // Reveal correct action bg
    const doneBg    = outer.querySelector('.rec-action-bg.done');
    const dismissBg = outer.querySelector('.rec-action-bg.dismiss');
    if (currentX > 0) {
      doneBg.style.opacity    = Math.min(1, currentX / THRESHOLD);
      dismissBg.style.opacity = 0;
    } else {
      dismissBg.style.opacity = Math.min(1, -currentX / THRESHOLD);
      doneBg.style.opacity    = 0;
    }
 
    // Rubber-band effect beyond threshold
    const resistance = Math.abs(currentX) > THRESHOLD ? 0.3 : 1;
    const tx = currentX > THRESHOLD
      ? THRESHOLD + (currentX - THRESHOLD) * resistance
      : currentX < -THRESHOLD
        ? -THRESHOLD + (currentX + THRESHOLD) * resistance
        : currentX;
 
    front.style.transform = `translateX(${tx}px)`;
  }
 
  function onEnd() {
    if (!dragging) return;
    dragging = false;
    front.classList.remove('swiping');
 
    const doneBg    = outer.querySelector('.rec-action-bg.done');
    const dismissBg = outer.querySelector('.rec-action-bg.dismiss');
    doneBg.style.opacity = 0;
    dismissBg.style.opacity = 0;
 
    if (currentX > THRESHOLD) {
      // Swipe right → Done
      front.classList.add('snap-out');
      front.style.transform = `translateX(120%)`;
      setTimeout(() => {
        recState[cardId] = 'done';
        buildRecCards();
        showRecToast('✓ ทำแล้ว! บันทึกไว้แล้ว', '#34d399');
      }, 280);
    } else if (currentX < -THRESHOLD) {
      // Swipe left → Dismiss
      front.classList.add('snap-out');
      front.style.transform = `translateX(-120%)`;
      setTimeout(() => {
        recState[cardId] = 'dismissed';
        buildRecCards();
        showRecToast('ข้ามคำแนะนำนี้แล้ว', '#f87171');
      }, 280);
    } else {
      // Snap back
      front.classList.add('snap-back');
      front.style.transform = 'translateX(0)';
    }
    currentX = 0;
  }
 
  // Touch
  front.addEventListener('touchstart', e => onStart(e.touches[0].clientX), {passive:true});
  front.addEventListener('touchmove',  e => onMove(e.touches[0].clientX),  {passive:true});
  front.addEventListener('touchend',   () => onEnd());
 
  // Mouse
  front.addEventListener('mousedown',  e => { onStart(e.clientX); e.preventDefault(); });
  window.addEventListener('mousemove', e => { if (dragging) onMove(e.clientX); });
  window.addEventListener('mouseup',   () => { if (dragging) onEnd(); });
}
 
function showRecToast(msg, color) {
  const t = document.createElement('div');
  t.textContent = msg;
  t.style.cssText = `
    position:absolute;bottom:110px;left:50%;transform:translateX(-50%);
    background:${color};color:white;font-size:12px;font-weight:600;
    padding:8px 18px;border-radius:20px;z-index:300;
    box-shadow:0 4px 16px rgba(0,0,0,0.2);white-space:nowrap;
    animation:recToastAnim 2.2s cubic-bezier(0.16,1,0.3,1) forwards;`;
  const phone = document.querySelector('.phone');
  if (phone) phone.appendChild(t);
  setTimeout(() => t.remove(), 2200);
}
 
// Add toast keyframe
const recStyle = document.createElement('style');
recStyle.textContent = `@keyframes recToastAnim {
  0%   { opacity:0; transform:translateX(-50%) translateY(10px); }
  15%  { opacity:1; transform:translateX(-50%) translateY(0); }
  75%  { opacity:1; }
  100% { opacity:0; transform:translateX(-50%) translateY(-6px); }
}`;
document.head.appendChild(recStyle);
 
// ── Settings Panel ──────────────────────────────────────
 
// Auto-init
setTimeout(() => { buildCitySelector(); initTempChartIfNeeded(); setTimeout(buildRecCards, 300); }, 100);
</script>
