async function refreshTempData() {
  const liveLabel = document.getElementById('tempLiveLabel');
  if (liveLabel) liveLabel.innerHTML = `<div style="width:6px;height:6px;border-radius:50%;background:#f59e0b;animation:tempBlink 0.5s ease-in-out infinite;"></div><span style="font-size:8px;color:#c2700a;font-weight:500;">กำลังโหลด...</span>`;
 
  if (!checkOWMKey()) {
    if (liveLabel) liveLabel.innerHTML = `<div style="width:6px;height:6px;border-radius:50%;background:#e07060;"></div><span style="font-size:8px;color:#c0443a;font-weight:500;">ไม่มี API Key</span>`;
    return;
  }
 
  // Fetch both in parallel
  const [current, forecast] = await Promise.all([
    fetchOWMCurrent(owmCity),
    fetchOWMHourly(owmCity),
  ]);
 
  if (!current && !forecast) {
    if (liveLabel) liveLabel.innerHTML = `<div style="width:6px;height:6px;border-radius:50%;background:#e07060;"></div><span style="font-size:8px;color:#c0443a;font-weight:500;">เชื่อมต่อไม่ได้</span>`;
    const subEl = document.getElementById('tempTimeRange');
    if (subEl) subEl.innerHTML = `<span style="color:#c0443a;">⚠ API Key ไม่ถูกต้อง · </span><a href="#" onclick="promptOWMKey()" style="color:var(--rose-dk);">เปลี่ยน Key</a>`;
    return;
  }
 
  // Build unified data:
  // Slot 0 = current (real-time), Slots 1-5 = forecast (3h intervals)
  // Smooth: interpolate between current and first forecast to avoid jump
  const times  = [];
  const values = [];
 
  if (current) {
    times.push(current.time);   // e.g. "15:32"
    values.push(current.temp);
  }
 
  if (forecast) {
    forecast.forEach((f, i) => {
      // Skip first forecast slot if it's within 1h of current (avoid duplicate)
      if (current && i === 0) {
        // Blend: midpoint between current and first forecast
        const blended = Math.round(((current.temp + f.temp) / 2) * 10) / 10;
        const nowH = new Date().getHours();
        const fH   = parseInt(f.time);
        const midH = Math.round((nowH + fH) / 2);
        times.push(midH.toString().padStart(2,'0') + ':00');
        values.push(blended);
      }
      times.push(f.time);
      values.push(f.temp);
    });
  }
 
  // Apply smoothing: clamp swings > 3°C between adjacent points
  for (let i = 1; i < values.length; i++) {
    const diff = values[i] - values[i-1];
    if (Math.abs(diff) > 3) {
      values[i] = Math.round((values[i-1] + Math.sign(diff) * 3) * 10) / 10;
    }
  }
 
  // Take first 6 points only
  TEMP_DATA.times  = times.slice(0, 6);
  TEMP_DATA.values = values.slice(0, 6);
  tempLiveVal      = current ? current.temp : values[0];
 
  // Update header — current temp (real-time, first slot)
  const peakEl = document.getElementById('tempPeakVal');
  if (peakEl && current) peakEl.textContent = current.temp.toFixed(2) + '°C';
 
  const subEl = document.getElementById('tempTimeRange');
  if (subEl && current) subEl.textContent = `📍 ${owmCity} · ${current.desc} · 💧${current.humidity}%`;
 
  if (liveLabel) liveLabel.innerHTML = `<div style="width:6px;height:6px;border-radius:50%;background:#7dce82;animation:tempBlink 1.2s ease-in-out infinite;"></div><span style="font-size:8px;color:#5aaa60;font-weight:500;">LIVE · ${owmCity}</span>`;
 
  // Re-animate with new data
  if (tempAnimRAF) cancelAnimationFrame(tempAnimRAF);
  tempAnimProgress = 0;
  tempIntroAnimate();
}
 
