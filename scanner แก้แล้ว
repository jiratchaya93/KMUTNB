// Ripple helper
function addRipple(btn, e) {
  const r = document.createElement('span');
  r.className = 'ripple';
  const rect = btn.getBoundingClientRect();
  const sz = Math.max(rect.width, rect.height);
  const x = (e && e.clientX ? e.clientX : rect.left + rect.width/2) - rect.left - sz/2;
  const y = (e && e.clientY ? e.clientY : rect.top + rect.height/2) - rect.top - sz/2;
  r.style.cssText = `width:${sz}px;height:${sz}px;left:${x}px;top:${y}px`;
  btn.appendChild(r);
  setTimeout(() => r.remove(), 600);
}
 
// Auto-start camera on load
window.addEventListener('load', () => startCamera());
async function startCamera() {
  try {
    const stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } }
    });
    video.srcObject = stream;
    video.onloadedmetadata = () => {
      placeholder.style.display = 'none';
      statusDot.classList.add('live');
      statusText.textContent = 'LIVE';
      btnScan.disabled = false;
    };
  } catch(err) {
    placeholder.querySelector('span').textContent = 'ไม่สามารถเข้าถึงกล้องได้';
    statusText.textContent = 'ข้อผิดพลาด';
  }
}
 
async function captureAndScan(e) {
  addRipple(btnScan, e);
  btnScan.disabled = true;
  spinner.style.display = 'block';
  btnLabel.textContent = 'กำลังประมวลผล...';
  scanLine.classList.add('active');
  ocrText.className = '';
  ocrText.textContent = 'กำลังอ่านข้อมูล โปรดรอสักครู่...';
  progressWrap.style.display = 'block';
  progressBar.style.width = '0%';
  resultBox.classList.remove('has-result');
 
  const ctx = canvas.getContext('2d');
  canvas.width  = video.videoWidth;
  canvas.height = video.videoHeight;
  ctx.drawImage(video, 0, 0);
 
  try {
    const result = await Tesseract.recognize(canvas.toDataURL('image/png'), 'eng', {
      logger: m => {
        if (m.status === 'recognizing text')
          progressBar.style.width = Math.round(m.progress * 100) + '%';
      }
    });
    scanLine.classList.remove('active');
    progressBar.style.width = '100%';
    setTimeout(() => { progressWrap.style.display = 'none'; progressBar.style.width = '0%'; }, 600);
    const text = result.data.text.trim();
    if (text) {
      ocrText.textContent = text;
      ocrText.classList.add('found');
      resultBox.classList.add('has-result');
    } else {
      ocrText.textContent = 'ไม่พบข้อความ กรุณาลองอีกครั้ง';
    }
  } catch(err) {
    scanLine.classList.remove('active');
    progressWrap.style.display = 'none';
    ocrText.textContent = 'เกิดข้อผิดพลาด: ' + err.message;
  }
  btnScan.disabled = false;
  spinner.style.display = 'none';
  btnLabel.textContent = '📷 สแกนข้อมูลพลังงาน';
}
 
// ── Interactive Energy Chart ─────────────────────────────
const CHART_DATA = {
  '6h':  { labels:['12:00','13:00','14:00','15:00','16:00','17:00'], values:[48,55,62,77.5,71,58], unit:'kW', cost:92 },
  '24h': { labels:['00:00','03:00','06:00','09:00','12:00','15:00','18:00','21:00','24:00'],
           values:[28,22,18,35,52,77.5,65,48,42], unit:'kW', cost:152 },
  '7d':  { labels:['จ','อ','พ','พฤ','ศ','ส','อา'], values:[210,195,240,185,265,310,180], unit:'kW/d', cost:1064 }
};
let activeDataKey = '24h';
let scrubIdx = -1;
 
function getChartCanvas() { return document.getElementById('energyChart'); }
 
function drawChart(key, scrub) {
  const canvas = getChartCanvas();
  if (!canvas) return;
  const wrap = document.getElementById('chartWrap');
  const W = wrap.clientWidth;
  const H = 115;
  canvas.width  = W * window.devicePixelRatio;
  canvas.height = H * window.devicePixelRatio;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
 
  const data   = CHART_DATA[key];
  const vals   = data.values;
  const labels = data.labels;
  const pad = { l:26, r:10, t:12, b:22 };
  const cw = W - pad.l - pad.r;
  const ch = H - pad.t - pad.b;
  const maxV = Math.max(...vals);
  const minV = 0;
  const range = maxV - minV || 1;
  const n = vals.length;
 
  const px = i => pad.l + (i / (n-1)) * cw;
  const py = v => pad.t + ch - ((v - minV) / range) * ch;
 
  // Grid lines + Y labels
  ctx.font = `${8 * window.devicePixelRatio / window.devicePixelRatio}px DM Sans`;
  ctx.fillStyle = 'rgba(156,123,116,0.6)';
  ctx.textAlign = 'right';
  [0.25, 0.5, 0.75, 1.0].forEach(frac => {
    const v   = minV + range * frac;
    const y   = py(v);
    ctx.strokeStyle = 'rgba(180,100,80,0.07)';
    ctx.lineWidth   = 1;
    ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(W - pad.r, y); ctx.stroke();
    ctx.fillText(Math.round(v), pad.l - 3, y + 3);
  });
 
  // Area fill (gradient)
  const grad = ctx.createLinearGradient(0, pad.t, 0, pad.t + ch);
  grad.addColorStop(0,   'rgba(232,165,152,0.42)');
  grad.addColorStop(1,   'rgba(232,165,152,0.02)');
  ctx.beginPath();
  ctx.moveTo(px(0), py(vals[0]));
  for (let i = 1; i < n; i++) {
    const xm = (px(i-1) + px(i)) / 2;
    ctx.bezierCurveTo(xm, py(vals[i-1]), xm, py(vals[i]), px(i), py(vals[i]));
  }
  ctx.lineTo(px(n-1), pad.t + ch);
  ctx.lineTo(px(0),   pad.t + ch);
  ctx.closePath();
  ctx.fillStyle = grad;
  ctx.fill();
 
  // Line stroke (gradient left→right)
  const lineGrad = ctx.createLinearGradient(pad.l, 0, W - pad.r, 0);
  lineGrad.addColorStop(0, '#f5c0b0');
  lineGrad.addColorStop(1, '#d4685a');
  ctx.beginPath();
  ctx.moveTo(px(0), py(vals[0]));
  for (let i = 1; i < n; i++) {
    const xm = (px(i-1) + px(i)) / 2;
    ctx.bezierCurveTo(xm, py(vals[i-1]), xm, py(vals[i]), px(i), py(vals[i]));
  }
  ctx.strokeStyle = lineGrad;
  ctx.lineWidth   = 2.2;
  ctx.lineJoin    = 'round';
  ctx.lineCap     = 'round';
  ctx.stroke();
 
  // X labels
  ctx.fillStyle = 'rgba(156,123,116,0.7)';
  ctx.textAlign = 'center';
  ctx.font = '8.5px DM Sans';
  labels.forEach((lbl, i) => {
    const xi = Math.round(i / (labels.length - 1) * (n - 1));
    if (xi < n) ctx.fillText(lbl, px(xi), H - 4);
  });
 
  // Peak dot (always show max)
  const peakIdx = vals.indexOf(maxV);
  ctx.beginPath();
  ctx.arc(px(peakIdx), py(maxV), 7, 0, Math.PI*2);
  ctx.fillStyle = 'rgba(224,112,96,0.18)';
  ctx.fill();
  ctx.beginPath();
  ctx.arc(px(peakIdx), py(maxV), 4.5, 0, Math.PI*2);
  ctx.fillStyle = '#e07060';
  ctx.fill();
 
  // Scrubber line + dot
  if (scrub >= 0 && scrub < n) {
    const sx = px(scrub), sy = py(vals[scrub]);
    // vertical line
    ctx.strokeStyle = 'rgba(224,112,96,0.45)';
    ctx.lineWidth   = 1.5;
    ctx.setLineDash([3,3]);
    ctx.beginPath(); ctx.moveTo(sx, pad.t); ctx.lineTo(sx, pad.t + ch); ctx.stroke();
    ctx.setLineDash([]);
    // dot ring
    ctx.beginPath(); ctx.arc(sx, sy, 8, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(224,112,96,0.2)'; ctx.fill();
    ctx.beginPath(); ctx.arc(sx, sy, 4.5, 0, Math.PI*2);
    ctx.fillStyle = '#e07060'; ctx.fill();
    ctx.beginPath(); ctx.arc(sx, sy, 2.5, 0, Math.PI*2);
    ctx.fillStyle = 'white'; ctx.fill();
 
    // update tooltip
    const tooltip = document.getElementById('scrubTooltip');
    const pct = sx / W * 100;
    tooltip.style.left  = pct + '%';
    tooltip.style.display = 'block';
    tooltip.textContent = '⚡ ' + vals[scrub] + ' ' + data.unit;
  } else {
    const tooltip = document.getElementById('scrubTooltip');
    if (tooltip) tooltip.style.display = 'none';
  }
}
 
function posToIdx(clientX, canvas) {
  const rect  = canvas.getBoundingClientRect();
  const x     = clientX - rect.left;
  const data  = CHART_DATA[activeDataKey];
  const n     = data.values.length;
  const W     = rect.width;
  const pad_l = 26, pad_r = 10;
  const cw    = W - pad_l - pad_r;
  const frac  = (x - pad_l) / cw;
  return Math.max(0, Math.min(n-1, Math.round(frac * (n-1))));
}
 
function initChartEvents() {
  const canvas = getChartCanvas();
  if (!canvas) return;
 
  const onMove = (clientX) => {
    scrubIdx = posToIdx(clientX, canvas);
    drawChart(activeDataKey, scrubIdx);
    const v = CHART_DATA[activeDataKey].values[scrubIdx];
    const u = CHART_DATA[activeDataKey].unit;
    document.getElementById('chartPeakVal').innerHTML =
      `${v} <span style="font-size:13px;font-family:'DM Sans',sans-serif;font-weight:300;color:var(--muted)">${u}</span>`;
  };
  const onEnd = () => {
    scrubIdx = -1;
    drawChart(activeDataKey, -1);
    const peak = Math.max(...CHART_DATA[activeDataKey].values);
    document.getElementById('chartPeakVal').innerHTML =
      `${peak} <span style="font-size:13px;font-family:'DM Sans',sans-serif;font-weight:300;color:var(--muted)">${CHART_DATA[activeDataKey].unit}</span>`;
  };
 
  canvas.addEventListener('touchstart',  e => { e.preventDefault(); onMove(e.touches[0].clientX); }, {passive:false});
  canvas.addEventListener('touchmove',   e => { e.preventDefault(); onMove(e.touches[0].clientX); }, {passive:false});
  canvas.addEventListener('touchend',    () => onEnd());
  canvas.addEventListener('mousedown',   e => onMove(e.clientX));
  canvas.addEventListener('mousemove',   e => { if (e.buttons) onMove(e.clientX); });
  canvas.addEventListener('mouseleave',  () => onEnd());
  canvas.addEventListener('mouseup',     () => onEnd());
}
 
function switchChartData(key) {
  activeDataKey = key;
  scrubIdx = -1;
  const data = CHART_DATA[key];
  const peak = Math.max(...data.values);
  const peakIdx = data.values.indexOf(peak);
  document.getElementById('chartPeakVal').innerHTML =
    `${peak} <span style="font-size:13px;font-family:'DM Sans',sans-serif;font-weight:300;color:var(--muted)">${data.unit}</span>`;
  document.getElementById('chartMaxVal').innerHTML  = `${peak} <em>${data.unit}</em>`;
  document.getElementById('chartMaxTime').textContent = data.labels[Math.round(peakIdx/(data.values.length-1)*(data.labels.length-1))] + ' น.';
  document.getElementById('chartCost').innerHTML    = `${data.cost} <em>บาท</em>`;
  drawChart(key, -1);
}
 
// Init chart after DOM ready
