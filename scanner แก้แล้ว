function monthNav(dir) {
  mIdx = Math.max(0, Math.min(MONTHS.length-1, mIdx+dir));
  renderMonthCarousel();
}
function jumpMonth(i) { mIdx = i; renderMonthCarousel(); }
 
// Touch swipe support
(function(){
  let sx=0;
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('monthTrack');
    if (!track) return;
    track.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, {passive:true});
    track.addEventListener('touchend',   e => {
      const dx = e.changedTouches[0].clientX - sx;
      if (Math.abs(dx) > 40) monthNav(dx < 0 ? 1 : -1);
    }, {passive:true});
  });
})();
 
