const NOTIF_ITEMS = [
  { id:'n_peak',    label:'แจ้งเตือน Peak Demand', sub:'เมื่อค่าไฟสูงเกินกำหนด', on:true  },
  { id:'n_bill',    label:'แจ้งเตือนค่าไฟ',        sub:'เมื่อใกล้วันออกบิล',      on:true  },
  { id:'n_saving',  label:'คำแนะนำประหยัดไฟ',      sub:'ทุกวันเวลา 08:00 น.',    on:false },
  { id:'n_update',  label:'อัปเดตระบบ',            sub:'แจ้งเมื่อมีเวอร์ชันใหม่', on:true  },
];
const notifState = {};
NOTIF_ITEMS.forEach(n => notifState[n.id] = n.on);
 
const apiState = { mea:false, pea:false, ha:false };
 
function openSettings() {
  document.getElementById('settingsOverlay').style.opacity = '1';
  document.getElementById('settingsOverlay').style.pointerEvents = 'all';
  document.getElementById('settingsPanel').style.transform = 'translateX(0)';
  buildNotifRows();
}
function closeSettings() {
  document.getElementById('settingsOverlay').style.opacity = '0';
  document.getElementById('settingsOverlay').style.pointerEvents = 'none';
  document.getElementById('settingsPanel').style.transform = 'translateX(100%)';
}
 
function buildNotifRows() {
  const el = document.getElementById('notifRows');
  if (!el) return;
  el.innerHTML = NOTIF_ITEMS.map((n,i) => `
    <div style="display:flex;align-items:center;gap:12px;padding:12px 14px;
      ${i<NOTIF_ITEMS.length-1?'border-bottom:1px solid rgba(232,165,152,0.1);':''}">
      <div style="flex:1">
        <div style="font-size:12.5px;font-weight:500;color:var(--text);">${n.label}</div>
        <div style="font-size:10.5px;color:var(--muted);margin-top:1px;">${n.sub}</div>
      </div>
      <div onclick="toggleNotif('${n.id}',this)" style="
        width:40px;height:22px;border-radius:11px;
        background:${notifState[n.id]?'var(--rose)':'#ddd'};
        position:relative;cursor:pointer;transition:background 0.25s;flex-shrink:0;">
        <div style="
          position:absolute;top:3px;left:${notifState[n.id]?'19':'3'}px;
          width:16px;height:16px;border-radius:50%;background:white;
          box-shadow:0 1px 4px rgba(0,0,0,0.2);
          transition:left 0.25s;"></div>
      </div>
    </div>`).join('');
}
 
function toggleNotif(id, el) {
  notifState[id] = !notifState[id];
  buildNotifRows();
}
 
function toggleApi(api, btn) {
  apiState[api] = !apiState[api];
  const on = apiState[api];
  btn.textContent = on ? 'ยกเลิก' : 'เชื่อมต่อ';
  btn.style.background = on ? 'rgba(125,206,130,0.2)' : 'linear-gradient(135deg,#efaa9a,#e07060)';
  btn.style.color = on ? '#3a8a40' : 'white';
  btn.style.boxShadow = on ? 'none' : '0 3px 8px rgba(224,112,96,0.3)';
  const statusEl = document.getElementById(api+'Status');
  if (statusEl) {
    statusEl.textContent = on ? '✓ เชื่อมตแล้ว' : 'ไม่ได้เชื่อมต่อ';
    statusEl.style.color = on ? '#3a8a40' : '';
  }
}
 
