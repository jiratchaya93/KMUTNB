  <title>Energy Scanner</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/tesseract.js@4/dist/tesseract.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --rose: #e8a598; --rose-dk: #c97b6e; --rose-lt: #f5d5cc;
      --cream: #fdf6f2; --text: #3a2a25; --muted: #9c7b74;
      --glass: rgba(255,255,255,0.72);
      --shadow: 0 8px 28px rgba(180,100,80,0.13);
      --shadow-sm: 0 4px 14px rgba(180,100,80,0.09);
    }
    html, body {
      height: 100%; font-family: "DM Sans", sans-serif;
      background: var(--cream);
      display: flex; justify-content: center; align-items: center;
      overflow: hidden;
    }
    body::before, body::after {
      content: ""; position: fixed; border-radius: 50%;
      filter: blur(80px); opacity: 0.48; pointer-events: none; z-index: 0;
    }
    body::before {
      width: 520px; height: 520px;
      background: radial-gradient(circle, #f0b8a8, #f5d5cc);
      top: -120px; right: -80px;
      animation: drift1 12s ease-in-out infinite alternate;
    }
    body::after {
      width: 400px; height: 400px;
      background: radial-gradient(circle, #e8cfc8, #f8ebe6);
      bottom: -100px; left: -60px;
      animation: drift2 14s ease-in-out infinite alternate;
    }
    @keyframes drift1 { to { transform: translate(-30px,40px) scale(1.05); } }
    @keyframes drift2 { to { transform: translate(30px,-30px) scale(1.08); } }
    .petal {
      position: fixed; border-radius: 0 60% 0 60%;
      background: rgba(232,165,152,0.32); pointer-events: none;
      animation: fall linear infinite; z-index: 0;
    }
    @keyframes fall {
      0% { transform: translateY(-20px) rotate(0deg); opacity: 0; }
      10% { opacity: 1; } 90% { opacity: 0.45; }
      100% { transform: translateY(110vh) rotate(720deg) scale(0.4); opacity: 0; }
    }
    .phone {
      position: relative; z-index: 10;
      width: 375px; height: 780px;
      display: flex; flex-direction: column;
      background: rgba(255,255,255,0.72);
      backdrop-filter: blur(22px); -webkit-backdrop-filter: blur(22px);
      border: 1px solid rgba(255,255,255,0.82); border-radius: 40px;
      box-shadow: 0 20px 60px rgba(180,100,80,0.15), inset 0 1px 0 rgba(255,255,255,0.9);
      overflow: hidden;
      animation: rise 0.8s cubic-bezier(0.16,1,0.3,1) both;
    }
    @keyframes rise {
      from { opacity: 0; transform: translateY(36px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .phone::before {
      content: ""; position: absolute; top: 0; left: 40px; right: 40px; height: 3px;
      background: linear-gradient(90deg, transparent, var(--rose), transparent);
      border-radius: 0 0 4px 4px; z-index: 20; pointer-events: none;
    }
    @keyframes fadein { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
    .fi { animation: fadein 0.5s cubic-bezier(0.16,1,0.3,1) both; }
    .avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, #f2b8a8, #e88070);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 12px rgba(232,128,112,0.3); font-size: 15px;
    }
    .bottom-nav {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 10px 20px 18px;
      background: rgba(253,246,242,0.9); backdrop-filter: blur(16px);
      border-top: 1px solid rgba(232,165,152,0.14); z-index: 100; border-radius: 0 0 40px 40px;
    }
    .nav-row { display: flex; justify-content: space-around; align-items: center; }
    .nav-item { display: flex; flex-direction: column; align-items: center; gap: 5px; cursor: pointer; }
    .nav-icon {
      width: 58px; height: 58px; border-radius: 16px;
      background: rgba(255,255,255,0.62); border: 1px solid rgba(255,255,255,0.88);
      box-shadow: 0 4px 16px rgba(180,90,70,0.10), inset 0 1px 0 rgba(255,255,255,0.95);
      display: flex; align-items: center; justify-content: center;
      position: relative; overflow: hidden; transition: transform 0.18s, box-shadow 0.18s;
    }
    .nav-icon::before {
      content: ""; position: absolute; top: 0; left: 0; right: 0; height: 52%;
      background: linear-gradient(to bottom, rgba(255,255,255,0.55), rgba(255,255,255,0.08));
      border-radius: 16px 16px 60% 60% / 16px 16px 40% 40%;
      pointer-events: none; z-index: 2;
    }
    .nav-icon.active-icon {
      background: linear-gradient(135deg, #efaa9a, #e07060);
      box-shadow: 0 6px 20px rgba(224,112,96,0.38), inset 0 1px 0 rgba(255,255,255,0.35);
    }
    .nav-icon svg { width: 32px; height: 32px; position: relative; z-index: 1; }
    .nav-item:hover .nav-icon { transform: translateY(-3px) scale(1.04); }
    .nav-label { font-size: 10.5px; color: var(--muted); font-weight: 400; }
    .nav-label.active-label { color: var(--rose-dk); font-weight: 500; }
    .ripple {
      position: absolute; border-radius: 50%;
      background: rgba(255,255,255,0.3); transform: scale(0);
      animation: ripple-anim 0.55s linear; pointer-events: none;
    }
    @keyframes ripple-anim { to { transform: scale(5); opacity: 0; } }
    .spinner { width: 16px; height: 16px; border: 2.5px solid rgba(255,255,255,0.4); border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; display: none; }
    @keyframes spin { to { transform: rotate(360deg); } }
    canvas { display: none; }
    #v-scanner {
      justify-content: flex-start; background: transparent;
    }
    .scanner-inner {
      flex: 1; overflow-y: auto; padding: 0 16px 100px;
      scrollbar-width: none;
    }
    .scanner-inner::-webkit-scrollbar { display: none; }
 
    .scan-header { padding: 18px 22px 12px; display: flex; justify-content: space-between; align-items: center; }
    .scan-header h1 {
      font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 400;
      color: var(--text); letter-spacing: 0.01em;
    }
    .scan-header p { font-size: 12px; color: var(--muted); font-weight: 300; margin-top: 1px; }
 
    .camera-wrap {
      position: relative; border-radius: 20px; overflow: hidden;
      background: #1a0e0b; aspect-ratio: 4/3; margin-bottom: 14px;
      box-shadow: 0 8px 24px rgba(180,100,80,0.18);
    }
    #video { width: 100%; height: 100%; object-fit: cover; display: block; }
 
    .scan-frame {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 78%; height: 42%; pointer-events: none;
    }
    .scan-frame::before, .scan-frame::after, .scan-frame .c-br, .scan-frame .c-bl {
      content: ''; position: absolute; width: 20px; height: 20px;
      border-color: var(--rose); border-style: solid;
    }
    .scan-frame::before { top:0; left:0;  border-width: 2.5px 0 0 2.5px; border-radius: 4px 0 0 0; }
    .scan-frame::after  { top:0; right:0; border-width: 2.5px 2.5px 0 0; border-radius: 0 4px 0 0; }
    .scan-frame .c-br   { bottom:0; right:0; border-width: 0 2.5px 2.5px 0; border-radius: 0 0 4px 0; }
    .scan-frame .c-bl   { bottom:0; left:0;  border-width: 0 0 2.5px 2.5px; border-radius: 0 0 0 4px; }
 
    .scan-line {
      position: absolute; left: 11%; right: 11%; height: 2px;
      background: linear-gradient(90deg, transparent, var(--rose), transparent);
      top: 29%; border-radius: 2px; opacity: 0; pointer-events: none;
    }
    .scan-line.active { animation: laser 1.8s ease-in-out infinite; opacity: 1; }
    @keyframes laser {
      0%   { transform: translateY(0); opacity: 0; }
      10%  { opacity: 1; }
      50%  { transform: translateY(50px); }
      90%  { opacity: 1; }
      100% { transform: translateY(0); opacity: 0; }
    }
 
    .cam-placeholder {
      position: absolute; inset: 0; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 10px;
      color: rgba(255,255,255,0.35); font-size: 13px; font-weight: 300;
    }
    .cam-placeholder .cam-icon { font-size: 34px; opacity: 0.4; }
 
    .status-badge {
      position: absolute; top: 11px; right: 11px;
      background: rgba(0,0,0,0.42); backdrop-filter: blur(6px);
      border-radius: 20px; padding: 3px 10px; font-size: 11px;
      color: rgba(255,255,255,0.7); display: flex; align-items: center; gap: 5px;
    }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; background: #aaa; transition: background 0.3s; }
    .status-dot.live { background: #7dce82; animation: blink 1.2s ease-in-out infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.4} }
 
    .result-box {
      background: rgba(255,255,255,0.62); border: 1.5px solid rgba(232,165,152,0.2);
      border-radius: 18px; padding: 13px 15px; min-height: 68px;
      transition: border-color 0.3s; margin-bottom: 2px;
    }
    .result-box.has-result { border-color: rgba(232,165,152,0.45); }
